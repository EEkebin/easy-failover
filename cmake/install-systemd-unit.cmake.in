set(EASY_FAILOVER_INSTALL_BINDIR "@CMAKE_INSTALL_BINDIR@")
set(EASY_FAILOVER_INSTALL_SYSCONFDIR "@CMAKE_INSTALL_SYSCONFDIR@")
set(EASY_FAILOVER_SYSTEMD_UNIT_DIR "@EASY_FAILOVER_SYSTEMD_UNIT_DIR@")
set(EASY_FAILOVER_SYSTEMD_UNIT_TEMPLATE
    "@CMAKE_CURRENT_SOURCE_DIR@/packaging/systemd/easy-failover.service.in")

function(easy_failover_full_install_path output directory)
    if(IS_ABSOLUTE "${directory}")
        set("${output}" "${directory}" PARENT_SCOPE)
    else()
        set("${output}" "${CMAKE_INSTALL_PREFIX}/${directory}" PARENT_SCOPE)
    endif()
endfunction()

easy_failover_full_install_path(EASY_FAILOVER_SYSTEMD_BINDIR "${EASY_FAILOVER_INSTALL_BINDIR}")
easy_failover_full_install_path(
    EASY_FAILOVER_SYSTEMD_SYSCONFDIR
    "${EASY_FAILOVER_INSTALL_SYSCONFDIR}")
easy_failover_full_install_path(
    EASY_FAILOVER_SYSTEMD_UNIT_FULL_DIR
    "${EASY_FAILOVER_SYSTEMD_UNIT_DIR}")

file(READ "${EASY_FAILOVER_SYSTEMD_UNIT_TEMPLATE}" EASY_FAILOVER_SYSTEMD_UNIT_CONTENT)
string(CONFIGURE "${EASY_FAILOVER_SYSTEMD_UNIT_CONTENT}" EASY_FAILOVER_SYSTEMD_UNIT_CONTENT @ONLY)

set(EASY_FAILOVER_SYSTEMD_UNIT_INSTALL_DIR
    "$ENV{DESTDIR}${EASY_FAILOVER_SYSTEMD_UNIT_FULL_DIR}")
file(MAKE_DIRECTORY "${EASY_FAILOVER_SYSTEMD_UNIT_INSTALL_DIR}")
file(
    WRITE
    "${EASY_FAILOVER_SYSTEMD_UNIT_INSTALL_DIR}/easy-failover.service"
    "${EASY_FAILOVER_SYSTEMD_UNIT_CONTENT}")
file(
    CHMOD
    "${EASY_FAILOVER_SYSTEMD_UNIT_INSTALL_DIR}/easy-failover.service"
    PERMISSIONS
    OWNER_READ
    OWNER_WRITE
    GROUP_READ
    WORLD_READ)
