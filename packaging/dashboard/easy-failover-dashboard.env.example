# Environment file for the easy-failover dashboard service.
# The package installs this as /etc/easy-failover-dashboard/dashboard.env (seeded
# from this example on first install). Edit and `systemctl restart
# easy-failover-dashboard`. See docs/dashboard-service.md.

# Listen address. The dashboard is read-only but unauthenticated; keep it on
# localhost (or a trusted interface) and front it with a reverse proxy / SSH
# tunnel for remote access.
HOSTNAME=127.0.0.1
PORT=3000
NODE_ENV=production

# Multi-node roster (server-side). A JSON file of node entries the dashboard
# proxies to. If unset, the dashboard falls back to EASY_FAILOVER_NODES, then to
# a single local node.
#EASY_FAILOVER_NODES_FILE=/etc/easy-failover-dashboard/nodes.json

# Single-node fallback API base (used when no roster is configured).
NEXT_PUBLIC_EASY_FAILOVER_API_BASE=http://127.0.0.1:8743

# SSH onboarding is privileged and DENY-BY-DEFAULT. Leave unset to keep it off.
# Only enable behind the authenticated write API / a trusted operator session.
#EASY_FAILOVER_ONBOARD_ENABLED=true
