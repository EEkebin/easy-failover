# Environment file for the easy-failover dashboard service.
# The package installs this as /etc/easy-failover-dashboard/dashboard.env (seeded
# from this example on first install). Edit and `systemctl restart
# easy-failover-dashboard`. See docs/dashboard-service.md.

# Listen address. Defaults to 127.0.0.1 (localhost only) because the dashboard is
# UNAUTHENTICATED and, once a write token is provisioned (see below), its Apply button
# can change node config. Binding it to the network would expose an unauthenticated
# write panel. Reach it remotely with an SSH tunnel:
#   ssh -L 3000:localhost:3000 user@node    # then open http://localhost:3000
# Only set HOSTNAME=0.0.0.0 if you put real auth / a reverse proxy in front of it.
HOSTNAME=127.0.0.1
PORT=3000
NODE_ENV=production

# Multi-node roster (server-side). A JSON file of node entries the dashboard
# proxies to, and where onboarding appends new nodes. It lives in the service's
# writable StateDirectory (/var/lib/easy-failover-dashboard, created by systemd).
# Keep it there: /etc is read-only under the unit's ProtectSystem=strict, so a
# roster under /etc could not be written by onboarding.
EASY_FAILOVER_NODES_FILE=/var/lib/easy-failover-dashboard/nodes.json

# Single-node fallback API base (used when no roster is configured).
NEXT_PUBLIC_EASY_FAILOVER_API_BASE=http://127.0.0.1:8743

# Write token for the local node. The package auto-provisions this on first install:
# it generates the same token the daemon uses (/etc/easy-failover/api.token) and appends
# it here, and creates a roster entry (nodes.json) whose "tokenEnv" points at this name.
# That is what makes the dashboard's Apply button work for the local node out of the box.
# This file is therefore a SECRET (mode 0640, group easy-failover-dashboard). The value
# never reaches the browser. To rotate: change it here AND in the daemon's token file.
#EASY_FAILOVER_TOKEN_LOCAL=

# SSH onboarding is privileged and DENY-BY-DEFAULT. Leave unset to keep it off.
# Only enable behind the authenticated write API / a trusted operator session.
#EASY_FAILOVER_ONBOARD_ENABLED=true
