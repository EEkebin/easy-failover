# Example environment file for the easy-failover dashboard service.
# Copy to /etc/easy-failover/dashboard.env and edit as needed.
#
# NOTE: NEXT_PUBLIC_EASY_FAILOVER_API_BASE is a build-time public variable in
# Next.js. It is baked into the build during `npm run build`, so setting it here
# only takes effect if it matches what was set before the build. Rebuild the
# dashboard after changing the API base. See docs/dashboard-service.md.

# Point the dashboard at the local API of the node it is served from.
# Default if unset: http://127.0.0.1:8743
NEXT_PUBLIC_EASY_FAILOVER_API_BASE=http://127.0.0.1:8743

# Port the production server listens on (Next.js default is 3000).
PORT=3000

NODE_ENV=production
