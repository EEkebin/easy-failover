#!/bin/sh
# Debian/Ubuntu post-remove for the easy-failover DAEMON: drop config only on purge (Debian
# convention). The dashboard package cleans up its own config/state/user.
set -e

case "$1" in
    purge)
        # `apt purge` removes all local config, including the generated write token
        # (/etc/easy-failover/api.token).
        rm -rf /etc/easy-failover
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload || true
        fi
        ;;
    remove)
        if command -v systemctl >/dev/null 2>&1; then
            systemctl daemon-reload || true
            systemctl reset-failed easy-failover.service || true
        fi
        ;;
esac

exit 0
