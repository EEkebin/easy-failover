#!/bin/sh
# Debian/Ubuntu pre-remove: stop the service and release the VIP on real removal.
set -e

case "$1" in
    remove)
        if command -v systemctl >/dev/null 2>&1; then
            systemctl stop easy-failover.service || true
            systemctl disable easy-failover.service || true
            systemctl stop easy-failover-dashboard.service || true
            systemctl disable easy-failover-dashboard.service || true
        fi
        # Best-effort: release the VIP from this host if it owns it, so a
        # decommissioned node does not leave the address stranded. Never fails the
        # removal. Only on real removal — not upgrade or deconfigure.
        if [ -x /usr/bin/easy-failover ] && [ -e /etc/easy-failover/config.toml ]; then
            /usr/bin/easy-failover --config /etc/easy-failover/config.toml --release-vip || true
        fi
        ;;
    upgrade|deconfigure)
        # Keep the VIP and the running service across upgrades and transient
        # deconfigure events (the package is expected to be reconfigured, not
        # removed).
        ;;
esac

exit 0
