#!/bin/sh
# runit run script for the easy-failover virtual IP failover agent.
#
# runit supervises the process directly, so the agent runs in the foreground
# with --run-forever and must not daemonize. Redirect stderr to stdout so the
# companion log service captures both streams.
exec 2>&1
exec @EASY_FAILOVER_RUNIT_BINDIR@/easy-failover \
	--config @EASY_FAILOVER_RUNIT_SYSCONFDIR@/easy-failover/config.toml \
	--run-forever
